# Lottery 配置文件示例

[data]
raw_file = "data/raw_ssq.txt"
db_file = "data/lottery.duckdb"
# source: raw | duckdb | auto（默认：有 DuckDB 数据则用库，否则读 raw）
source = "auto"

[output]
base_dir = "output"
models_dir = "output/models"
logs_dir = "output/logs"
summaries_dir = "output/summaries"

[training]
epochs = 100
batch_size = 32
learning_rate = 0.001
val_split = 0.2
